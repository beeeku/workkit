{
	"name": "@workkit/browser",
	"version": "0.1.0",
	"description": "Cloudflare Browser Rendering primitive — session/page lifecycle, font loading, normalized errors",
	"license": "MIT",
	"author": "Bikash Dash <beeeku>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/beeeku/workkit.git",
		"directory": "packages/browser"
	},
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bunup",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@workkit/errors": "^1.0.3"
	},
	"peerDependencies": {
		"@cloudflare/puppeteer": ">=0.0.14"
	},
	"peerDependenciesMeta": {
		"@cloudflare/puppeteer": {
			"optional": true
		}
	},
	"devDependencies": {
		"@cloudflare/puppeteer": "^0.0.14"
	},
	"keywords": [
		"cloudflare",
		"workers",
		"browser",
		"browser-rendering",
		"puppeteer",
		"workkit"
	]
}
