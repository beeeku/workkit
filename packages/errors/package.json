{
  "name": "@workkit/errors",
  "version": "0.0.1",
  "description": "Structured error types with retry classification for Cloudflare Workers",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/errors"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@workkit/types": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@workkit/types": {
      "optional": true
    }
  },
  "devDependencies": {
    "@workkit/types": "workspace:*",
    "bunup": "0.16.31",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "errors",
    "retry",
    "workkit"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
