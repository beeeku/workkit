{
  "name": "@workkit/kv",
  "version": "0.2.1",
  "description": "Typed KV operations with Standard Schema validation for Cloudflare Workers",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/kv"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/errors": "workspace:*"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.0.0",
    "@workkit/types": "workspace:*",
    "zod": "^4.3.6",
    "valibot": "^1.0.0"
  },
  "peerDependencies": {
    "@standard-schema/spec": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@standard-schema/spec": {
      "optional": true
    }
  },
  "keywords": [
    "cloudflare",
    "workers",
    "kv",
    "key-value",
    "typed",
    "standard-schema",
    "workkit"
  ]
}
