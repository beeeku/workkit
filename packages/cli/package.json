{
  "name": "workkit",
  "version": "0.0.1",
  "description": "CLI for the workkit Cloudflare Workers utility suite \u2014 scaffolding, validation, migrations, and code generation",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "workkit": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.5.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "cli",
    "scaffolding",
    "code-generation",
    "workkit"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
