{
	"name": "@workkit/agent",
	"version": "0.0.0",
	"description": "Composable agent loop primitives — typed tools (Standard Schema), handoffs, streaming, hooks. Provider-agnostic via @workkit/ai-gateway.",
	"license": "MIT",
	"author": "Bikash Dash <beeeku>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/beeeku/workkit.git",
		"directory": "packages/agent"
	},
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bunup",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@standard-schema/spec": "^1.1.0",
		"@workkit/ai-gateway": "workspace:*",
		"@workkit/errors": "^1.0.2"
	},
	"devDependencies": {
		"valibot": "^1.3.1",
		"zod": "^3.23.0"
	},
	"keywords": [
		"cloudflare",
		"workers",
		"agent",
		"ai",
		"tools",
		"workkit"
	]
}
