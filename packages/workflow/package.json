{
  "name": "@workkit/workflow",
  "version": "0.1.0",
  "description": "Durable workflow execution on Cloudflare Workers — checkpoint, replay, saga compensation",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/workflow"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/errors": "workspace:*"
  },
  "devDependencies": {
    "@workkit/do": "workspace:*",
    "@workkit/types": "workspace:*",
    "@cloudflare/workers-types": "^4.20250214.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "workflow",
    "durable",
    "saga",
    "agent",
    "workkit"
  ]
}
