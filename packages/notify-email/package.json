{
	"name": "@workkit/notify-email",
	"version": "0.0.0",
	"description": "Email transport adapter for @workkit/notify — Resend HTTP API, optional React Email rendering, Svix webhook verification, auto-opt-out on bounce/complaint.",
	"license": "MIT",
	"author": "Bikash Dash <beeeku>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/beeeku/workkit.git",
		"directory": "packages/notify-email"
	},
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bunup",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@workkit/errors": "^1.0.2",
		"@workkit/notify": "workspace:*"
	},
	"peerDependencies": {
		"@react-email/render": ">=1.0.0"
	},
	"peerDependenciesMeta": {
		"@react-email/render": {
			"optional": true
		}
	},
	"keywords": [
		"cloudflare",
		"workers",
		"notify",
		"email",
		"resend",
		"react-email",
		"workkit"
	]
}
