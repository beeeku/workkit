{
  "name": "@workkit/testing",
  "version": "0.0.1",
  "description": "Mock factories for Cloudflare Workers bindings and test utilities",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/testing"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./kv": {
      "import": {
        "types": "./dist/kv.d.ts",
        "default": "./dist/kv.js"
      }
    },
    "./d1": {
      "import": {
        "types": "./dist/d1.d.ts",
        "default": "./dist/d1.js"
      }
    },
    "./r2": {
      "import": {
        "types": "./dist/r2.d.ts",
        "default": "./dist/r2.js"
      }
    },
    "./queue": {
      "import": {
        "types": "./dist/queue.d.ts",
        "default": "./dist/queue.js"
      }
    },
    "./do": {
      "import": {
        "types": "./dist/do.d.ts",
        "default": "./dist/do.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "testing",
    "mock",
    "kv",
    "d1",
    "r2",
    "queue",
    "durable-objects",
    "workkit"
  ]
}
