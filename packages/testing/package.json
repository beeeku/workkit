{
  "name": "@workkit/testing",
  "version": "0.4.0",
  "description": "Mock factories for Cloudflare Workers bindings and test utilities",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/testing"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    },
    "./kv": {
      "import": {
        "types": "./dist/src/kv.d.ts",
        "default": "./dist/src/kv.js"
      }
    },
    "./d1": {
      "import": {
        "types": "./dist/src/d1.d.ts",
        "default": "./dist/src/d1.js"
      }
    },
    "./r2": {
      "import": {
        "types": "./dist/src/r2.d.ts",
        "default": "./dist/src/r2.js"
      }
    },
    "./queue": {
      "import": {
        "types": "./dist/src/queue.d.ts",
        "default": "./dist/src/queue.js"
      }
    },
    "./do": {
      "import": {
        "types": "./dist/src/do.d.ts",
        "default": "./dist/src/do.js"
      }
    },
    "./email": {
      "import": {
        "types": "./dist/src/email.d.ts",
        "default": "./dist/src/email.js"
      }
    }
  },
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "//constitution-allow": "no-testing reason=self-package; @workkit/testing cannot depend on itself",
  "keywords": [
    "cloudflare",
    "workers",
    "testing",
    "mock",
    "kv",
    "d1",
    "r2",
    "queue",
    "durable-objects",
    "email",
    "send-email",
    "workkit"
  ]
}
