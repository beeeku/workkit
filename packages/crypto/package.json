{
  "name": "@workkit/crypto",
  "version": "0.0.1",
  "description": "Ergonomic WebCrypto wrappers for Cloudflare Workers — AES-256-GCM, HKDF, envelope encryption, hashing",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/crypto"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./derive": {
      "import": {
        "types": "./dist/derive.d.ts",
        "default": "./dist/derive.js"
      }
    },
    "./envelope": {
      "import": {
        "types": "./dist/envelope.d.ts",
        "default": "./dist/envelope.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250310.0",
    "bunup": "0.16.31",
    "expect-type": "^1.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "crypto",
    "webcrypto",
    "encryption",
    "aes-gcm",
    "hkdf",
    "workkit"
  ]
}
