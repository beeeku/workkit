{
  "name": "@workkit/env",
  "version": "0.1.0",
  "description": "Typed environment bindings with Standard Schema validation for Cloudflare Workers",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/env"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./validators": {
      "import": {
        "types": "./dist/validators.d.ts",
        "default": "./dist/validators.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/errors": "workspace:*"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.0.0",
    "arktype": "^2.2.0",
    "valibot": "^1.3.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@standard-schema/spec": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@standard-schema/spec": {
      "optional": true
    }
  },
  "keywords": [
    "cloudflare",
    "workers",
    "env",
    "environment",
    "validation",
    "standard-schema",
    "d1",
    "kv",
    "r2",
    "durable-objects",
    "workkit"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
