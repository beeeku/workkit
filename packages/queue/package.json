{
  "name": "@workkit/queue",
  "version": "0.2.0",
  "description": "Ergonomic typed queue producer/consumer patterns for Cloudflare Workers Queues",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/queue"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/types": "workspace:*",
    "@workkit/errors": "workspace:*"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "queue",
    "producer",
    "consumer",
    "typed",
    "workkit"
  ]
}
