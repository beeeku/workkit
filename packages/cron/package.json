{
  "name": "@workkit/cron",
  "version": "0.1.1",
  "description": "Cron trigger patterns for Cloudflare Workers — declarative scheduled task handlers with distributed locking",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/cron"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/errors": "workspace:*"
  },
  "devDependencies": {
    "@workkit/types": "workspace:*"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "cron",
    "scheduled",
    "tasks",
    "distributed-lock",
    "workkit"
  ]
}
