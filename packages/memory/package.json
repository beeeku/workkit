{
  "name": "@workkit/memory",
  "version": "0.2.1",
  "description": "Edge-native agent memory — facts, recall, conversations, temporal queries on Cloudflare Workers",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/memory"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/errors": "workspace:*"
  },
  "devDependencies": {
    "@workkit/crypto": "workspace:*",
    "@workkit/types": "workspace:*",
    "@cloudflare/workers-types": "^4.20250214.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "memory",
    "agent",
    "ai",
    "rag",
    "vector",
    "workkit"
  ]
}
