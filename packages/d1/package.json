{
  "name": "@workkit/d1",
  "version": "0.1.1",
  "description": "Type-safe D1 query helpers with query builder, batch operations, and migrations for Cloudflare Workers",
  "license": "MIT",
  "author": "Bikash Dash",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/d1"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./migrate": {
      "import": {
        "types": "./dist/migrate.d.ts",
        "default": "./dist/migrate.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "d1",
    "database",
    "sqlite",
    "typed",
    "query-builder",
    "migrations",
    "workkit"
  ],
  "dependencies": {
    "@workkit/errors": "^1.0.1"
  },
  "devDependencies": {
    "@workkit/types": "workspace:*"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  }
}
