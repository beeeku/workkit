{
  "name": "@workkit/mail",
  "version": "0.1.0",
  "description": "Typed email client for Cloudflare Workers — send, receive, route, parse",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/mail"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/types": "^1.0.1",
    "@workkit/errors": "^1.0.1",
    "mimetext": "^3.0.24",
    "postal-mime": "^2.4.1"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "email",
    "mail",
    "workkit"
  ]
}
