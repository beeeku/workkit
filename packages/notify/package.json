{
	"name": "@workkit/notify",
	"version": "0.0.0",
	"description": "Unified notification dispatch for Cloudflare Workers — preferences, opt-out, quiet hours, idempotency, fallback chains. Pluggable transport adapters.",
	"license": "MIT",
	"author": "Bikash Dash <beeeku>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/beeeku/workkit.git",
		"directory": "packages/notify"
	},
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bunup",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@standard-schema/spec": "^1.1.0",
		"@workkit/errors": "^1.0.2"
	},
	"devDependencies": {
		"zod": "^3.23.0"
	},
	"keywords": [
		"cloudflare",
		"workers",
		"notify",
		"notifications",
		"workkit"
	]
}
