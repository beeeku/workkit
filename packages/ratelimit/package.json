{
  "name": "@workkit/ratelimit",
  "version": "0.2.2",
  "description": "Rate limiting primitives for Cloudflare Workers — fixed window, sliding window, and token bucket algorithms",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "packages/ratelimit"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/types": "^1.0.1",
    "@workkit/errors": "^1.0.4"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "rate-limit",
    "ratelimit",
    "throttle",
    "token-bucket",
    "sliding-window",
    "workkit"
  ]
}
