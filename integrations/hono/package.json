{
  "name": "@workkit/hono",
  "version": "0.0.1",
  "description": "Hono middleware that integrates workkit utilities — env validation, error handling, rate limiting, caching",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beeeku/workkit",
    "directory": "integrations/hono"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/types": "workspace:*",
    "@workkit/errors": "workspace:*",
    "@workkit/env": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250310.0",
    "bunup": "0.16.31",
    "expect-type": "^1.1.0",
    "hono": "^4.7.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "hono",
    "middleware",
    "env",
    "validation",
    "error-handler",
    "rate-limit",
    "cache",
    "workkit"
  ]
}
