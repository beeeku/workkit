{
  "name": "@workkit/hono",
  "version": "0.0.1",
  "description": "Hono middleware that integrates workkit utilities \u2014 env validation, error handling, rate limiting, caching",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "integrations/hono"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/errors": "workspace:*",
    "@workkit/env": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "@workkit/types": "workspace:*",
    "hono": "^4.7.0",
    "zod": "^4.3.6"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "hono",
    "middleware",
    "env",
    "validation",
    "error-handler",
    "rate-limit",
    "cache",
    "workkit"
  ]
}
