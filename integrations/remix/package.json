{
  "name": "@workkit/remix",
  "version": "0.1.1",
  "description": "Remix integration for Cloudflare Workers — typed loader/action helpers, env validation, error boundaries",
  "license": "MIT",
  "author": "Bikash Dash <beeeku>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeeku/workkit.git",
    "directory": "integrations/remix"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@workkit/env": "^0.1.1",
    "@workkit/errors": "^1.0.1",
    "@workkit/types": "^1.0.1"
  },
  "peerDependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "remix",
    "loader",
    "action",
    "env",
    "validation",
    "typed",
    "workkit"
  ]
}
