{
  "name": "workkit",
  "private": true,
  "workspaces": ["packages/*", "integrations/*", "tooling/*", "apps/*"],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build && node scripts/resolve-workspace-deps.js && changeset publish && node scripts/resolve-workspace-deps.js --restore",
    "test:e2e": "vitest run --config e2e/vitest.config.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "^2.30.0",
    "@clack/prompts": "^1.2.0",
    "@cloudflare/workers-types": "^4.20260408.1",
    "@standard-schema/spec": "^1.1.0",
    "@workkit/api": "workspace:*",
    "@workkit/auth": "workspace:*",
    "@workkit/cache": "workspace:*",
    "@workkit/crypto": "workspace:*",
    "@workkit/d1": "workspace:*",
    "@workkit/env": "workspace:*",
    "@workkit/errors": "workspace:*",
    "@workkit/kv": "workspace:*",
    "@workkit/ratelimit": "workspace:*",
    "@workkit/testing": "workspace:*",
    "bunup": "0.16.31",
    "picocolors": "^1.1.1",
    "turbo": "^2.9.5",
    "typescript": "^5.7.0",
    "valibot": "^1.3.1",
    "vitest": "^3.0.0"
  },
  "packageManager": "bun@1.3.8"
}
