{
  "name": "workkit",
  "private": true,
  "workspaces": ["packages/*", "integrations/*", "tooling/*"],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "biome check .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build && changeset publish",
    "test:e2e": "vitest run --config e2e/vitest.config.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@cloudflare/workers-types": "^4.20250310.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@biomejs/biome": "1.9.4",
    "bunup": "0.16.31"
  },
  "packageManager": "bun@1.3.8"
}
