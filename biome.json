{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "formatter": {
    "enabled": true,
    "indentStyle": "tab",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "files": {
    "include": [
      "packages/**/*.ts",
      "packages/**/*.tsx",
      "integrations/**/*.ts",
      "integrations/**/*.tsx",
      "tooling/**/*.ts"
    ],
    "ignore": [
      "**/node_modules",
      "**/dist",
      "**/.turbo"
    ]
  }
}
